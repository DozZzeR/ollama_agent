TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_CHAT_IDS=123456789,987654321

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_TIMEOUT_MS=60000

AGENT_MAX_STEPS=10

# true (default) = model always gets tools, decides itself when to use them
# false = triage keyword scoring decides: simple messages get no tools (DIRECT mode)
# Use false for weak/small models that hallucinate tool calls
FORCE_TOOL_LOOP=true

TOOL_TIMEOUT_MS=10000
TOOL_MAX_RESPONSE_BYTES=32768

# info = normal logging, debug = full LLM call logging to debug_log table in SQLite
# Use: node debug_viewer.js        — view last 10 calls
# Use: node debug_viewer.js full 20 — view last 20 calls with full messages
LOG_LEVEL=info
